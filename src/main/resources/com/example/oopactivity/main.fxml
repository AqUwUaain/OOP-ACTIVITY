<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.oopactivity.controller.Controller"
            style="-fx-background-color: #f8fafc;">

    <center>

        <VBox spacing="20"
              alignment="TOP_CENTER"
              style="-fx-padding: 30;">

            <!-- TITLE -->

            <Label text="Student Management">

                <font>
                    <Font size="30"/>
                </font>

                <style>
                    -fx-font-weight: bold;
                    -fx-text-fill: #0f172a;
                </style>

            </Label>

            <!-- FORM CARD -->

            <HBox spacing="30">

                <VBox spacing="15"
                      prefWidth="350"
                      style="
                      -fx-background-color: white;
                      -fx-background-radius: 15;
                      -fx-padding: 25;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15,0,0,4);
                      ">

                    <!-- NAME -->

                    <Label text="Student Name"
                           style="-fx-font-size: 14; -fx-font-weight: bold;"/>

                    <TextField fx:id="txtName"
                               promptText="Enter full name"
                               prefHeight="40"
                               style="
                               -fx-background-radius: 10;
                               -fx-border-radius: 10;
                               -fx-font-size: 14;
                               "/>

                    <!-- COURSE -->

                    <Label text="Course"
                           style="-fx-font-size: 14; -fx-font-weight: bold;"/>

                    <TextField fx:id="txtCourse"
                               promptText="Enter course"
                               prefHeight="40"
                               style="
                               -fx-background-radius: 10;
                               -fx-border-radius: 10;
                               -fx-font-size: 14;
                               "/>

                    <!-- YEAR -->

                    <Label text="Year Level"
                           style="-fx-font-size: 14; -fx-font-weight: bold;"/>

                    <ChoiceBox fx:id="cbYear"
                               prefHeight="40"
                               prefWidth="300"
                               style="
                               -fx-background-radius: 10;
                               -fx-font-size: 14;
                               "/>

                    <!-- BUTTONS -->

                    <HBox spacing="10"
                          alignment="CENTER">

                        <Button text="Add"
                                onAction="#addStudent"
                                prefWidth="80"
                                prefHeight="40"
                                style="
                                -fx-background-color: #22c55e;
                                -fx-text-fill: white;
                                -fx-font-weight: bold;
                                -fx-background-radius: 10;
                                "/>

                        <Button text="Update"
                                onAction="#updateStudent"
                                prefWidth="80"
                                prefHeight="40"
                                style="
                                -fx-background-color: #3b82f6;
                                -fx-text-fill: white;
                                -fx-font-weight: bold;
                                -fx-background-radius: 10;
                                "/>

                        <Button text="Delete"
                                onAction="#deleteStudent"
                                prefWidth="80"
                                prefHeight="40"
                                style="
                                -fx-background-color: #ef4444;
                                -fx-text-fill: white;
                                -fx-font-weight: bold;
                                -fx-background-radius: 10;
                                "/>

                        <Button text="Clear"
                                onAction="#clearFields"
                                prefWidth="80"
                                prefHeight="40"
                                style="
                                -fx-background-color: #64748b;
                                -fx-text-fill: white;
                                -fx-font-weight: bold;
                                -fx-background-radius: 10;
                                "/>

                    </HBox>

                </VBox>

            </HBox>

            <!-- TABLE CARD -->

            <VBox prefWidth="950"
                  spacing="10"
                  style="
                  -fx-background-color: white;
                  -fx-background-radius: 15;
                  -fx-padding: 20;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15,0,0,4);
                  ">

                <Label text="Student Records"
                       style="
                       -fx-font-size: 20;
                       -fx-font-weight: bold;
                       -fx-text-fill: #0f172a;
                       "/>

                <TableView fx:id="table"
                           prefHeight="400"
                           style="
                           -fx-background-radius: 10;
                           -fx-border-radius: 10;
                           ">

                    <columns>

                        <TableColumn fx:id="colId"
                                     text="ID"
                                     prefWidth="100"/>

                        <TableColumn fx:id="colName"
                                     text="Name"
                                     prefWidth="300"/>

                        <TableColumn fx:id="colCourse"
                                     text="Course"
                                     prefWidth="250"/>

                        <TableColumn fx:id="colYear"
                                     text="Year Level"
                                     prefWidth="250"/>

                    </columns>

                </TableView>

            </VBox>

        </VBox>

    </center>

</BorderPane>